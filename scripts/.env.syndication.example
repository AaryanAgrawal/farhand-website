# Content Pipeline API Keys
# Copy this file to .env.syndication and fill in your keys

# ── Content Generation ──
# KoalaWriter — https://koala.sh → Account → API Key
KOALA_API_KEY=

# Search Atlas REST API — https://sa.searchatlas.com
# Header: x-api-key. Grab from Search Atlas dashboard → Settings → API, or
# copy from ~/.claude/settings.json if the Search Atlas MCP is already
# installed locally. Used by content-pipeline.ts commands:
#   sa-status     OTTO project + site audit overview
#   sa-issues     Open issue groups ranked by health_to_gain
#   sa-recrawl    Trigger a fresh site audit crawl
#   sa-snapshot   Dump project + audit + issues JSON for trend tracking
SEARCHATLAS_API_KEY=

# Optional — override the OTTO project UUID. Default is Farhand's project,
# hard-coded in scripts/content-pipeline.ts.
# SEARCHATLAS_OTTO_UUID=

# ── Syndication Platforms ──
# Dev.to — https://dev.to/settings/extensions → Generate API Key
DEVTO_API_KEY=

# Hashnode — https://hashnode.com/settings/developer
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# Medium — https://medium.com/me/settings → Integration tokens
MEDIUM_TOKEN=

# Tumblr — https://www.tumblr.com/oauth/apps
TUMBLR_TOKEN=
TUMBLR_BLOG_NAME=

# Telegraph — https://telegra.ph (call createAccount once to mint a token)
TELEGRAPH_ACCESS_TOKEN=

# ── Cover Image Generation ──
# OpenAI DALL-E 3 — https://platform.openai.com/api-keys (~$0.08/image hd)
# Used first if set. Generates branded cover images via DALL-E 3 at 1792x1024.
OPENAI_API_KEY=

# Unsplash — https://unsplash.com/oauth/applications (free)
# Fallback provider if OPENAI_API_KEY is not set. Pulls stock photos at 1200x630.
UNSPLASH_ACCESS_KEY=
