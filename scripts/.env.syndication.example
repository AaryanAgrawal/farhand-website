# Content Syndication API Keys
# Copy this file to .env.syndication and fill in your keys

# Dev.to — https://dev.to/settings/extensions → Generate API Key
DEVTO_API_KEY=

# Hashnode — https://hashnode.com/settings/developer → Personal Access Token
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# Medium — https://medium.com/me/settings → Integration tokens
MEDIUM_TOKEN=

# Tumblr — https://www.tumblr.com/oauth/apps → Register application
TUMBLR_TOKEN=
TUMBLR_BLOG_NAME=
